# Copy this file to .env and fill in your values.
# Only ONE provider section needs to be configured.

# ---------------------------------------------------------------------------
# Option 1: Ollama (RECOMMENDED — completely free, no API key needed)
# ---------------------------------------------------------------------------
# 1. Install Ollama from https://ollama.com
# 2. Pull a model:   ollama pull llama3.2
# 3. Set these vars (or leave at defaults — shown below):
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Option 2: Google Gemini (free tier — get a free key at https://aistudio.google.com/apikey)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=google
# GOOGLE_API_KEY=AIza_your_key_here
# GOOGLE_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Option 3: DeepSeek (very cheap / free credits — https://platform.deepseek.com)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-your_deepseek_key_here
# DEEPSEEK_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# Option 4: Groq (free cloud tier — sign up free at https://console.groq.com)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your_groq_key_here
# GROQ_MODEL=llama-3.1-70b-versatile

# ---------------------------------------------------------------------------
# Option 5: OpenAI (paid — requires a funded account)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_MODEL=gpt-4o

# Copy this file to .env and fill in your values.
# Only ONE provider section needs to be configured.
#
# When hosting online (Heroku / Railway / Render / Fly.io) set these as
# environment variables in your platform's dashboard instead of a .env file.

# ---------------------------------------------------------------------------
# Web server port (set automatically by most hosting platforms)
# ---------------------------------------------------------------------------
# PORT=5000

# ---------------------------------------------------------------------------
# Google Gemini (free tier — get a free key at https://aistudio.google.com/apikey)
#
# IMPORTANT: Create your key at aistudio.google.com/apikey (NOT via Google Cloud
# Console) to ensure the free-tier quota is automatically provisioned.
# ---------------------------------------------------------------------------
LLM_PROVIDER=google
GOOGLE_API_KEY=your_key_here
GOOGLE_MODEL=gemini-2.5-flash

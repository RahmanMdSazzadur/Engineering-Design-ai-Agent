# Copy this file to .env and fill in your values.
# Only ONE provider section needs to be configured.

# ---------------------------------------------------------------------------
# Option 1: Ollama (RECOMMENDED — completely free, no API key needed)
# ---------------------------------------------------------------------------
# 1. Install Ollama from https://ollama.com
# 2. Pull a model:   ollama pull llama3.2
# 3. Set these vars (or leave at defaults — shown below):
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Option 2: Groq (free cloud tier — sign up free at https://console.groq.com)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your_groq_key_here
# GROQ_MODEL=llama-3.1-70b-versatile

# ---------------------------------------------------------------------------
# Option 3: OpenAI (paid — requires a funded account)
# ---------------------------------------------------------------------------
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_MODEL=gpt-4o
